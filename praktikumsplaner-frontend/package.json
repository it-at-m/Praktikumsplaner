{
    "name": "praktikumsplaner-frontend-frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "security": "vite --mode developmentSecurity",
        "serve": "vite ",
        "build": "vite build && eslint . --fix && vue-tsc --noEmit",
        "test": "vitest run",
        "preview": "vite preview",
        "lint": "prettier . --check && eslint . && vue-tsc --noEmit --skipLibCheck",
        "fix": "prettier . --write && eslint . --fix",
        "type-check": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@fontsource/roboto": "5.2.10",
        "mitt": "3.0.1",
        "moment": "2.30.1",
        "pinia": "3.0.4",
        "vue": "3.5.29",
        "vue-i18n": "11.2.8",
        "vue-router": "4.6.4",
        "vuetify": "3.12.3"
    },
    "devDependencies": {
      "@cyclonedx/cyclonedx-npm": "4.2.0",
      "@eslint/js": "10.0.1",
      "@intlify/eslint-plugin-vue-i18n": "4.3.0",
      "@intlify/unplugin-vue-i18n": "11.0.7",
      "@mdi/js": "7.4.47",
      "@muenchen/prettier-codeformat": "1.0.2",
      "@pinia/testing": "1.0.3",
      "@tsconfig/node-lts": "24.0.0",
      "@types/node": "24.11.2",
      "@vitejs/plugin-vue": "6.0.4",
      "@vue/eslint-config-prettier": "10.2.0",
      "@vue/eslint-config-typescript": "14.7.0",
      "@vue/test-utils": "2.4.6",
      "@vue/tsconfig": "0.9.0",
      "eslint": "10.0.2",
      "eslint-plugin-vue": "10.8.0",
      "jsdom": "28.1.0",
      "prettier": "3.8.1",
      "typescript": "5.9.3",
      "unplugin-fonts": "1.4.0",
      "vite": "7.3.1",
      "vite-plugin-vue-devtools": "8.1.0",
      "vite-plugin-vuetify": "2.1.3",
      "vitest": "4.0.18",
      "vue-tsc": "3.2.5"
    }
}
